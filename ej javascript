dados dos numeros enteros, visualizar los comprendidos entre ambos. Y al final diga cuantos valores negativos hay y sumar los valores entre los dos numeros

*/
var num1=parseInt(prompt("Introduce el primer número"))
var num2=parseInt(prompt("Introduce el segundo número"))



function Visualizar1(num1,num2){
for (var i =num1 +1; i< num2; i++) {
    alert(i);
  }
}  

    var negativos=0;    
