<html>
<head>
  <title>Ejemplo de JavaScript</title>
  <meta charset="UTF-8">
</head>
<body>  
<script>
/*declara un array con una serie de valores. visualizar si se encuentra el valor -99*/
function Proceso (valores){
    sw=0;
    for (i=0; i<valores.length; i++){
        if (valores[i]==-99){
            sw=1;
        }
    }
    return sw;
}

function visualizar (resul){
    if (resul==1){
        alert("El valor -99 se encuentra en el array");
    }else{
        alert("El valor -99 no se encuentra en el array");
    }
}

let valores = [10, 20, -99, 30, 40];
resul = Proceso (valores);
visualizar(resul)
</script>   


</body>
</html>
